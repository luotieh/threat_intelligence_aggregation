# 外部情报源同步脚本的配置。复制为 intel_sources.env 并填入真实 key:
#   cp scripts/intel_sources.env.example scripts/intel_sources.env
# 运行:
#   set -a; source scripts/intel_sources.env; set +a
#   python3 scripts/otx_to_misp.py
#   python3 scripts/whoisxml_to_misp.py

# 本地 MISP(聚合层)
MISP_URL=https://localhost:8443
MISP_API_KEY=change-me

# AlienVault OTX (https://otx.alienvault.com/ -> Settings -> OTX Key)
OTX_API_KEY=change-me
# 首次运行回溯的天数 / 单次运行 pulse 上限
OTX_MODIFIED_SINCE=7
OTX_MAX_PULSES=200

# WhoisXML (https://threat-intelligence.whoisxmlapi.com/ -> My Products -> API Key)
WHOISXML_API_KEY=change-me
# 订阅内可用的 feed,逗号分隔;全部种类见 https://threat-intelligence.whoisxmlapi.com/specifications
WHOISXML_FEEDS=malicious-ips.v4,malicious-domains,malicious-urls,file-hashes
WHOISXML_MAX_PER_FEED=5000
